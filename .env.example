# ── Banco de dados MySQL (Acquahost) ─────────────────────────
DB_HOST=localhost
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco

# ── Certificado digital .pfx ─────────────────────────────────
# Coloque o arquivo em cert/certificado.pfx  (nunca suba ao git)
CERT_PASSWORD=senha_do_certificado

# ── Dados da transportadora ──────────────────────────────────
# CNPJ sem pontuação (14 dígitos)
CNPJ=00000000000000
# Código IBGE do estado da transportadora (ex: SP=35, RJ=33, MG=31)
UF_IBGE=35
